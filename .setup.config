# Project configuration consumed by the Taskfile and scripts/.
# These are non-secret project constants, so this file is committed.
# Secrets live in 1Password; per-developer 1Password account pinning lives in
# .1password.yml (gitignored, written by scripts/setup-1password.sh).

# Prefix for the 1Password vaults. Vaults are ${VAULT_PREFIX}-LOCAL and ${VAULT_PREFIX}-PROD.
VAULT_PREFIX=SKILL-TREE

# Docker Compose project name / container prefix (kebab-case).
APP_NAME=skill-tree-survey

# Host port the backend API is exposed on (container port is always 8000).
EXTERNAL_PORT=8000
