# Production Environment Variables
# Copy this to .env.production and update values

# Backend Configuration
ADMIN_PASSWORD=<PRODUCTION_ADMIN_PASSWORD>
DATABASE_URL=sqlite:////app/data/skill_survey.db

# CORS Configuration - IMPORTANT: Must be valid JSON array or comma-separated list
# Option 1: JSON array format (recommended)
CORS_ORIGINS=["http://<FRONTEND_DOMAIN>","http://<FRONTEND_IP>","http://<FRONTEND_IP>:80"]
# Example: CORS_ORIGINS=["http://skills-survey.heal.engineering","http://3.21.168.170","http://localhost:80"]

# Option 2: Comma-separated format (alternative)
# CORS_ORIGINS=http://<FRONTEND_DOMAIN>,http://<FRONTEND_IP>,http://<FRONTEND_IP>:80

# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@db:5432/skill_survey

# Frontend Configuration
VITE_API_URL=http://<BACKEND_IP>:8000
# Or if using same domain with reverse proxy:
# VITE_API_URL=/api

# Optional: PostgreSQL (uncomment if using PostgreSQL)
# POSTGRES_USER=skillsurvey
# POSTGRES_PASSWORD=your-db-password
# POSTGRES_DB=skill_survey