# Production Environment Variables with HTTPS

# Backend Configuration
ADMIN_PASSWORD=<PRODUCTION_ADMIN_PASSWORD>
DATABASE_URL=sqlite:////app/data/skill_survey.db

# Database Management
RESET_DATABASE=false

# CORS Configuration - Include both HTTP and HTTPS
CORS_ORIGINS=["https://skills-survey.heal.engineering","http://skills-survey.heal.engineering","http://<FRONTEND_IP>","http://<FRONTEND_IP>:80","http://localhost","http://localhost:80"]

# Frontend Configuration - Use the base domain without /api since nginx handles the routing
VITE_API_URL=https://skills-survey.heal.engineering