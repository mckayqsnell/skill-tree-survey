# ============================================================================
# Secrets & environment — values live in 1Password, never committed.
# (.setup.config IS committed: it holds non-secret project constants.)
# ============================================================================
.env
.env.*
.1password.yml

# SSL/certs (should never exist locally now that Cloudflare handles TLS)
*.pem
*.key
*.crt

# ============================================================================
# Python / backend (uv-managed)
# ============================================================================
__pycache__/
*.py[cod]
*.so
.venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# SQLite databases & the backend data dir
*.sqlite
*.sqlite3
*.db
backend/data/

# ============================================================================
# Node / frontend (pnpm + Vite)
# ============================================================================
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
.eslintcache
*-debug.log*
.vite/

# Vercel
.vercel

# ============================================================================
# Docker
# ============================================================================
docker-compose.override.yml

# ============================================================================
# Editors & OS
# ============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
